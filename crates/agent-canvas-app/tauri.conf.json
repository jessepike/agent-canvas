{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentCanvas",
  "version": "0.1.1",
  "identifier": "dev.jessepike.agentcanvas",
  "build": {
    "beforeBuildCommand": "cd ../ui && pnpm --filter . build",
    "beforeDevCommand": "cd ../ui && pnpm --filter . dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentCanvas",
        "width": 1280,
        "height": 780
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
