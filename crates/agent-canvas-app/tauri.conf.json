{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentCanvas",
  "version": "0.3.0",
  "identifier": "dev.jessepike.agentcanvas",
  "build": {
    "beforeBuildCommand": "cd ../ui && pnpm --filter . build",
    "beforeDevCommand": "cd ../ui && pnpm --filter . dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentCanvas",
        "width": 1280,
        "height": 780
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**/*"],
          "deny": [
            "/etc/**/*",
            "/System/**/*",
            "/private/etc/**/*",
            "/private/var/**/*",
            "/usr/**/*",
            "/var/**/*",
            "/Library/Application Support/AgentCanvas/**/*",
            "/Library/Application Support/Apple/**/*",
            "$HOME/Library/Application Support/AgentCanvas/**/*",
            "$HOME/Library/Application Support/com.apple/**/*"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
