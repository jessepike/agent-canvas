{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vellum",
  "version": "0.1.0",
  "identifier": "dev.jessepike.vellum",
  "build": {
    "beforeBuildCommand": "cd ../../ui && pnpm --filter . build",
    "beforeDevCommand": "cd ../../ui && pnpm --filter . dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vellum",
        "width": 1000,
        "height": 700
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
